# ============================================================================
# True North Atlas — environment variables
# Copy to .env for local development. On Render, set these per-service
# (render.yaml wires most of them; sync:false ones are set in the dashboard).
# ============================================================================

# ---- Postgres (API + worker) ----------------------------------------------
DATABASE_URL=postgres://user:pass@host:5432/atlas
# Render Postgres requires SSL (default). Set to "disable" for local dev only.
PGSSLMODE=require

# ---- Bitcoin Core JSON-RPC (worker) -----------------------------------------
# Core 25+ required (verbosity=3 getblock). Verified against Core 29.x.
# Node config needs: server=1 and rpcauth (or rpcuser/rpcpassword).
# txindex is NOT required.
BITCOIN_RPC_URL=http://127.0.0.1:8332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_RPC_TIMEOUT_MS=120000
RPC_MAX_RETRIES=4

# Start9 / Umbrel over Tor: set the .onion URL above and point this at a
# Tor SOCKS5 proxy. "socks5h" (not socks5) is required so DNS resolves via Tor.
# TOR_SOCKS_PROXY=socks5h://127.0.0.1:9050

# ---- Price data --------------------------------------------------------------
# Massive (formerly Polygon.io). When set: canonical daily closes from
# MASSIVE_CRYPTO_START forward AND the live header price (/api/spot).
# CryptoCompare remains solely as the deep-history backfill (2010 -> start),
# which the cost-basis engine requires. Unset = CryptoCompare for everything.
MASSIVE_API_KEY=
# MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_CRYPTO_START=2015-01-01
SPOT_CACHE_MS=30000
PRICE_PROVIDER=cryptocompare
CRYPTOCOMPARE_API_KEY=
# Override provider endpoints (testing / self-hosted proxies); normally leave unset.
# CRYPTOCOMPARE_BASE_URL=https://min-api.cryptocompare.com
# COINBASE_BASE_URL=https://api.exchange.coinbase.com

# ---- Sync worker tuning -------------------------------------------------------
SYNC_BATCH_BLOCKS=25
RPC_CONCURRENCY=4
PRUNE_DEPTH=144
REORG_SCAN_DEPTH=12
POLL_INTERVAL_MS=30000
STH_THRESHOLD_DAYS=155
ASOPR_MIN_AGE_SECONDS=3600
# SYNC_EXIT_AT_TIP=1        # cron mode: exit once caught up instead of polling
# SKIP_PRICE_SYNC=1         # skip price refresh on boot (tests / debugging)

# ---- Block explorer & private API -------------------------------------------------
# Secret that protects the key-admin endpoints (/api/admin/keys). Generate with:
#   openssl rand -base64 32
# If unset, the admin surface is disabled (safe default).
ADMIN_TOKEN=
# Free public explorer rate limit, per IP per minute (0 disables limiting).
PUBLIC_RATE_LIMIT_PER_MIN=60

# ---- Growth: shareable cards & email alerts ---------------------------------------
# Public origin of the frontend (links in emails and share pages point here).
PUBLIC_SITE_URL=https://atlas.tnorth.com
# Public origin of THIS API (used in confirmation/unsubscribe links and OG image URLs).
PUBLIC_API_URL=https://atlas-api.onrender.com
# Resend (resend.com) sends alert emails. Alerts are disabled if unset.
RESEND_API_KEY=
ALERTS_FROM_EMAIL=Atlas Alerts <alerts@tnorth.com>
ALERTS_CHECK_INTERVAL_MS=900000
# Signup kill switches (default OFF). Gate NEW signups only — unsubscribe
# links, pending confirmations, and already-confirmed alerts always work.
ALERT_SIGNUP_ENABLED=false
NEWSLETTER_SIGNUP_ENABLED=false
# RESEND_BASE_URL=https://api.resend.com   # override only for testing

# ---- API server ----------------------------------------------------------------
PORT=8080
CORS_ORIGIN=https://tnorth.com,https://www.tnorth.com
API_CACHE_SECONDS=300
LOG_LEVEL=info

# ---- Frontend (web/, build-time) -------------------------------------------------
# Absolute origin of the API when frontend and API are on different hosts.
VITE_API_URL=https://atlas-api.onrender.com
